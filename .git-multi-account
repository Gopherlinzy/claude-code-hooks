#!/bin/bash
# 多账户 Git 配置脚本

# 账户配置
GITHUB_HOST="github.com"
GITHUB_USER="linzy"
GITHUB_EMAIL="huzohulinyoujia@gmail.com"

GITLAB_HOST="gitcn.yostar.net"
GITLAB_USER="sunluyi"
GITLAB_EMAIL="sunluyi@yostar.net"

# 根据主机获取账户信息
get_account_info() {
    local host="$1"
    
    if [ "$host" = "$GITHUB_HOST" ]; then
        echo "$GITHUB_USER|$GITHUB_EMAIL"
    elif [ "$host" = "$GITLAB_HOST" ]; then
        echo "$GITLAB_USER|$GITLAB_EMAIL"
    else
        echo ""
    fi
}

# 获取主机名
get_host_from_url() {
    local url="$1"
    if [[ $url =~ git@([^:]+): ]]; then
        echo "${BASH_REMATCH[1]}"
    elif [[ $url =~ https://([^/]+)/ ]]; then
        echo "${BASH_REMATCH[1]}"
    fi
}

# 设置账户
set_account() {
    local host="$1"
    local account_info=$(get_account_info "$host")

    if [ -z "$account_info" ]; then
        echo "❌ 未知的主机：$host"
        return 1
    fi

    IFS='|' read -r name email <<< "$account_info"
    git config user.name "$name"
    git config user.email "$email"
    echo "✅ 已切换账户：$name <$email>"
}

# 自动检测远程并切换
auto_switch() {
    local tracking_branch=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)
    local remote=$(echo "$tracking_branch" | cut -d/ -f1)

    if [ -z "$remote" ] || [ "$remote" = "@{u}" ]; then
        remote="origin"
    fi

    local url=$(git config --get "remote.$remote.url")

    if [ -z "$url" ]; then
        echo "❌ 无法获取远程 URL"
        return 1
    fi

    local host=$(get_host_from_url "$url")

    if [ -z "$host" ]; then
        echo "❌ 无法解析主机信息"
        return 1
    fi

    set_account "$host"
}

# 显示所有配置
show_accounts() {
    echo "📋 已配置的账户："
    echo ""
    echo "  🐙 GitHub"
    echo "    主机：$GITHUB_HOST"
    echo "    用户名：$GITHUB_USER"
    echo "    邮箱：$GITHUB_EMAIL"
    echo ""
    echo "  🦊 GitLab"
    echo "    主机：$GITLAB_HOST"
    echo "    用户名：$GITLAB_USER"
    echo "    邮箱：$GITLAB_EMAIL"
    echo ""
}

# 主程序
case "${1:-auto}" in
    auto)
        auto_switch
        ;;
    show)
        show_accounts
        ;;
    set)
        if [ -z "$2" ]; then
            echo "❌ 请指定主机：$GITHUB_HOST 或 $GITLAB_HOST"
            exit 1
        fi
        set_account "$2"
        ;;
    *)
        echo "用法："
        echo "  $0 auto              - 自动检测远程并切换账户"
        echo "  $0 show              - 显示所有配置的账户"
        echo "  $0 set <host>        - 手动切换账户"
        exit 1
        ;;
esac
